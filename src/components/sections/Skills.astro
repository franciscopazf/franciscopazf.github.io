---
import Container from "../ui/Container.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import Badge from "../ui/Badge.astro";
import { technical, soft } from "../../data/skills";
---
<section id="skills" class="section">
  <Container>
  <SectionTitle title="Habilidades" subtitle="Tecnologías con las que trabajo" />
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <div class="card-glass rounded-2xl p-4 bg-zinc-800">
        <h4 class="font-semibold mb-2">Habilidades técnicas</h4>
        <div class="flex flex-wrap gap-3">
          {technical.map((s) => <Badge variant="blue">{s}</Badge>)}
        </div>
      </div>
      <div class="card-glass rounded-2xl p-4 bg-zinc-800">
        <h4 class="font-semibold mb-2">Habilidades blandas</h4>
        <ul class="list-disc ml-5 text-sm space-y-1 text-white/80">
          {soft.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </div>
  </Container>
</section>
