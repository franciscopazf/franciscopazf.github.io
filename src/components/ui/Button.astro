---
export interface Props {
  variant?: 'primary' | 'ghost' | 'outline';
  href?: string;
  target?: string;
}
const { variant = 'primary', href, target } = Astro.props as Props;
const base = "inline-flex items-center justify-center px-4 py-2 rounded-lg font-medium transition-transform transform hover:-translate-y-0.5 focus:outline-none";
let classes = base;
if (variant === 'primary') classes += ' bg-[color:var(--accent)] text-white hover:brightness-90';
if (variant === 'ghost') classes += ' bg-transparent text-white border border-white/10 hover:bg-white/5';
if (variant === 'outline') classes += ' bg-transparent text-[color:var(--accent)] border border-[color:rgba(20,184,166,0.2)] hover:bg-zinc-900/50';
---
{href ? (
  <a class={classes} href={href} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
