---
import Container from "../ui/Container.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import { projects } from "../../data/projects";
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
---
<section id="projects" class="section">
  <Container>
    <SectionTitle title="Proyectos" subtitle="Trabajos seleccionados" />
    <div class="mt-6 grid gap-6 md:grid-cols-2">
      {projects.map((p) => (
        <Card class="p-4 bg-zinc-800">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-lg font-semibold">{p.title}</h3>
              <p class="text-sm text-white/70 mt-2">{p.description}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {p.technologies.map((t) => <span class="text-xs px-2 py-1 bg-white/6 rounded-md">{t}</span>)}
              </div>
            </div>
            <div class="flex flex-col gap-2">
              {p.github ? <Button variant="outline" href={p.github} target="_blank">GitHub</Button> : null}
              {p.demo ? <Button href={p.demo} target="_blank">Sitio</Button> : null}
            </div>
          </div>
        </Card>
      ))}
    </div>
  </Container>
</section>
